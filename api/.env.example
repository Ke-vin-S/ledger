PORT=8080
ENV=local

DATABASE_URL=postgresql://dev:dev@localhost:5432/splitleger?sslmode=disable
REDIS_URL=redis://localhost:6379

# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then paste as single-line with \n for newlines, or use a multi-line value
JWT_PRIVATE_KEY=<RS256 PEM private key>
JWT_PUBLIC_KEY=<RS256 PEM public key>

S3_BUCKET=splitleger-receipts-dev
AWS_REGION=ap-southeast-1

# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>

FRONTEND_URL=http://localhost:3000
